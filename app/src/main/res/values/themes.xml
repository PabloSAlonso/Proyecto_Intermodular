<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Base Theme -->
    <style name="Base.Theme.Klyer" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/blue_primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/blue_ultra_light</item>
        <item name="colorOnPrimaryContainer">@color/blue_dark</item>
        <item name="colorSecondary">@color/blue_accent</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSecondaryContainer">@color/blue_soft</item>
        <item name="colorSurface">@color/surface_card</item>
        <item name="colorOnSurface">@color/text_dark</item>
        <item name="colorSurfaceVariant">@color/grey_light</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>
        <item name="android:windowBackground">@color/white_background</item>
        <item name="materialButtonStyle">@style/KlyerButton</item>
        <item name="textInputStyle">@style/KlyerTextInput</item>
        <item name="cardViewStyle">@style/KlyerCard</item>
    </style>

    <style name="Theme.Klyer" parent="Base.Theme.Klyer" />

    <!-- Circle Image Style -->
    <style name="CircleImage">
        <item name="cornerSize">50%</item>
    </style>

    <!-- Primary Button Style -->
    <style name="KlyerButton" parent="Widget.Material3.Button">
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="elevation">2dp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- Secondary Button Style -->
    <style name="KlyerButtonSecondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="strokeColor">@color/blue_primary</item>
        <item name="android:textColor">@color/blue_primary</item>
    </style>

    <!-- Text Button Style -->
    <style name="KlyerButtonText" parent="Widget.Material3.Button.TextButton">
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/blue_primary</item>
    </style>

    <!-- Text Input Style -->
    <style name="KlyerTextInput" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="boxStrokeColor">@color/blue_primary</item>
        <item name="hintTextColor">@color/blue_primary</item>
    </style>

    <!-- Card Style -->
    <style name="KlyerCard" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">2dp</item>
        <item name="cardBackgroundColor">@color/surface_card</item>
    </style>

    <!-- Card Outlined Style -->
    <style name="KlyerCardOutlined" parent="Widget.Material3.CardView.Outlined">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardBackgroundColor">@color/surface_card</item>
        <item name="strokeColor">@color/divider</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <!-- Bottom Navigation Style -->
    <style name="KlyerBottomNav" parent="Widget.Material3.BottomNavigationView">
        <item name="itemIconTint">@color/nav_item_color</item>
        <item name="itemTextColor">@color/nav_item_color</item>
        <item name="labelVisibilityMode">labeled</item>
    </style>

    <!-- Text Styles -->
    <style name="TextHeadline" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textColor">@color/text_dark</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextTitle" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/text_dark</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextBody" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/text_dark</item>
    </style>

    <style name="TextCaption" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textColor">@color/text_secondary</item>
    </style>

</resources>
